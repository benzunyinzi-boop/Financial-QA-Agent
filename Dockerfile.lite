# Dockerfile - 2核2G 优化版
# 策略：跳过前端构建阶段，直接复制已构建好的 dist/ 目录
# 优势：镜像更小、构建更快、不占用服务器内存
#
# 使用前提：
#   1. 在本地执行 ./deploy/build-frontend.sh 构建前端
#   2. 或者在本地执行 cd frontend && npm run build
#   3. 然后在 ECS 上使用 Dockerfile.lite 构建镜像

FROM python:3.9-slim

# 安装系统依赖（最小化）
RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc \
    g++ \
    curl \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# 先复制 requirements.txt 利用 Docker 缓存
COPY requirements.txt .

# 安装 Python 依赖
RUN pip install --no-cache-dir -r requirements.txt

# 复制项目代码（排除 frontend/node_modules 等）
COPY . .

# 确保 frontend/dist 存在（前端必须提前构建）
RUN if [ ! -d "/app/frontend/dist" ]; then \
      echo "ERROR: frontend/dist 不存在！请先在本地运行 'cd frontend && npm run build'" && \
      exit 1; \
    fi

# 创建数据目录
RUN mkdir -p /app/chroma_db /app/logs /app/data/uploads

EXPOSE 8000

HEALTHCHECK --interval=30s --timeout=10s --start-period=60s --retries=3 \
    CMD curl -f http://localhost:8000/api/v1/health || exit 1

CMD ["python", "start_api.py"]
